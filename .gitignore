# Repository allow-list
# By default, keep the repository focused on source code and required root files.
*
!/.gitignore
!/README.md
!/docker-compose.yml
!/docker-compose.prod.yml
!/quality-gate.ps1
!/.github/
!/.github/**
!/client/
!/client/**
!/server/
!/server/**
!/deploy/
!/deploy/**
!/docs/
!/docs/Media_Manual_Test_Checklist.md
!/docs/Media_Test_Findings_Summary.md
!/docs/ProductionDeployment.md
!/docs/CICD_Demo_Deployment_Guide.md
!/docs/interval-plan/
!/docs/interval-plan/Interval2BusinessLogicReport.md
!/scripts/
!/scripts/reset-demo-data.ps1
!/database/
!/database/smart_rental_demo_snapshot.dump
!/qa/
!/qa/wallet/
!/qa/wallet/README.md
!/qa/week05-api-testing/
!/qa/week05-api-testing/**

# Local agent/tooling output
.agent/
**/.agent/

# Secrets and local environment files
*.env
*.env.*
!.env.example
!client/.env.example
*.local
*.local.*
*.secret.*
secrets/
**/secrets/

# Private keys, certificate bundles, and provider credential exports
*.pem
*.key
*.pfx
*.p12
*.keystore
credentials*.json
service-account*.json

# Frontend dependencies, build output, and caches
node_modules/
client/node_modules/
client/dist/
client/.vite/
client/coverage/
client/.cache/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Python virtual environments and bytecode caches
.venv/
**/.venv/
__pycache__/
**/__pycache__/
*.py[cod]
.pytest_cache/
**/.pytest_cache/

# .NET build output and temporary files
server/nuget.config
**/[Bb]in/
**/[Oo]bj/
[Dd]ebug/
[Rr]elease/
[Tt]est[Rr]esult*/
**/[Tt]est[Rr]esults/
*.trx
*.coverage
*.coveragexml
*.nupkg
*.snupkg
*.binlog

# Test/coverage generated output
server/coverage-report/
server/artifacts/
server/tests/**/[Tt]est[Rr]esults/
server/tests/**/*.trx
server/tests/**/*.coverage
server/tests/**/*.coveragexml
server/tests/**/coverage.cobertura.xml

# Temporary files created while preparing/running backend tests
server/tests/*.log
server/tests/*.txt

# IDE/editor/user-specific files
.vs/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser
*.DotSettings.user
.idea/

# Logs and temporary files
*.log
api-debug*.log
*.tmp
*.temp
*.bak
*.swp
~$*
Thumbs.db
.DS_Store

# Runtime uploads/private files.
server/src/SmartRentalPlatform.Api/wwwroot/uploads/**
server/src/SmartRentalPlatform.Api/private-storage/**
deploy/secrets.local.md

# Database/runtime data
*.db
*.sqlite
*.sqlite3
*.mdf
*.ldf
*.ndf
docker/data/
**/data/local/
