# Repository allow-list
# By default, keep the repository focused on source code and required root files.
*
!/.gitignore
!/README.md
!/docker-compose.yml
!/client/
!/client/**
!/server/
!/server/**
!/qa/
!/qa/wallet/
!/qa/wallet/README.md

# Local agent/tooling output
.agent/
**/.agent/

# Secrets and local environment files
*.env
*.env.*
!.env.example
!client/.env.example
*.local
*.local.*
*.secret.*
secrets/
**/secrets/

# Commit appsettings files with safe defaults/placeholders only.
# Store real local values in .NET User Secrets or environment variables.

# Private keys, certificate bundles, and provider credential exports
*.pem
*.key
*.pfx
*.p12
*.keystore
credentials*.json
service-account*.json

# Frontend dependencies, build output, and caches
node_modules/
client/node_modules/
client/dist/
client/.vite/
client/coverage/
client/.cache/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# .NET build output and temporary files
**/[Bb]in/
**/[Oo]bj/
[Dd]ebug/
[Rr]elease/
[Tt]est[Rr]esult*/
*.trx
*.coverage
*.coveragexml
*.nupkg
*.snupkg
*.binlog

# IDE/editor/user-specific files
.vs/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser
*.DotSettings.user
.idea/

# Logs and temporary files
*.log
api-debug*.log
*.tmp
*.temp
*.bak
*.swp
~$*
Thumbs.db
.DS_Store

# Runtime uploads/private files.
server/src/SmartRentalPlatform.Api/wwwroot/uploads/**
server/src/SmartRentalPlatform.Api/private-storage/**

# Database/runtime data
*.db
*.sqlite
*.sqlite3
*.mdf
*.ldf
*.ndf
docker/data/
**/data/local/
