{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=smart_rental_platform;Username=postgres;Password=postgres"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "SeedData": {
    "Development": {
      "Enabled": false
    },
    "WalletQa": {
      "Enabled": false
    }
  },
  "Jwt": {
    "SecretKey": "your-super-secret-key-that-is-at-least-32-characters-long-for-development",
    "Issuer": "SmartRentalPlatform",
    "Audience": "SmartRentalPlatformUsers"
  },
  "Email": {
    "FromEmail": "no-reply@example.com",
    "FromName": "Smart Rental Platform",
    "Smtp": {
      "Host": "smtp.example.com",
      "Port": 587,
      "Username": "CHANGE_ME_SMTP_USERNAME",
      "Password": "CHANGE_ME_SMTP_PASSWORD",
      "UseSsl": false
    }
  },
  "PayOS": {
    "ClientId": "CHANGE_ME_PAYOS_CLIENT_ID",
    "ApiKey": "CHANGE_ME_PAYOS_API_KEY",
    "ChecksumKey": "CHANGE_ME_PAYOS_CHECKSUM_KEY",
    "BaseUrl": "https://api-merchant.payos.vn",
    "ReturnUrl": "http://localhost:5173/me/wallet/topups",
    "CancelUrl": "http://localhost:5173/me/wallet/topup"
  },
  "VietMap": {
    "BaseUrl": "https://maps.vietmap.vn",
    "ApiKey": "",
    "TimeoutSeconds": 20,
    "DisplayType": 5
  },
  "Gemini": {
    "ApiKey": "CHANGE_ME_GEMINI_API_KEY",
    "TimeoutSeconds": 20,
    "DisplayType": 5,
    "UseVertexAi": true,
    "ProjectId": "CHANGE_ME_PROJECT_ID",
    "Region": "us-central1",
    "ServiceAccountJson": "CHANGE_ME_SERVICE_ACCOUNT_JSON"
  },
  "ESign": {
    "Provider": "VnptEContract",
    "BaseUrl": "https://gateway-bus-econtract-v2-poc.vnpt.vn/",
    "ProductionBaseUrl": "https://gateway-bus-econtract.vnpt.vn/",
    "ClientId": "CHANGE_ME_ESIGN_CLIENT_ID",
    "ClientSecret": "CHANGE_ME_ESIGN_CLIENT_SECRET",
    "Username": "CHANGE_ME_ESIGN_USERNAME",
    "Password": "CHANGE_ME_ESIGN_PASSWORD",
    "NenTangId": 1,
    "LoaiTaiLieuId": "6",
    "WebhookCallbackKey": "CHANGE_ME_ESIGN_WEBHOOK_CALLBACK_KEY",
    "WebhookCallbackSecret": "CHANGE_ME_ESIGN_WEBHOOK_CALLBACK_SECRET",
    "CallbackUrl": "https://example.com/api/esign-webhooks/vnpt",
    "ReturnUrl": "http://localhost:5173/account/esign/return",
    "TokenCacheDurationMinutes": 50,
    "TimeoutSeconds": 30
  },
  "MeterAi": {
    "BaseUrl": "http://127.0.0.1:8001",
    "TimeoutSeconds": 45
  }
}